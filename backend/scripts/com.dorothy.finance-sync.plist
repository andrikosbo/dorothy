<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dorothy.finance-sync</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/Users/you/Projects/Dorothy/Dorothy/scripts/sync-elorus-finance.mjs</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/you/Projects/Dorothy/Dorothy</string>
