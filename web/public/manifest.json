{
  "name": "Dorothy",
  "short_name": "Dorothy",
  "id": "/",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#0c0d10",
  "theme_color": "#0c0d10",
  "description": "Private Dorothy assistant web client",
  "categories": ["productivity", "utilities"],
  "shortcuts": [
    {
      "name": "Νέα συζήτηση",
      "short_name": "Chat",
      "url": "/?view=chat"
    },
    {
      "name": "Σάρωση εγγράφου",
      "short_name": "Scan",
      "url": "/?view=documents"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": ["image/*", "application/pdf", "text/*"]
        }
      ]
    }
  },
  "user_preferences": {
    "prefers_color_scheme": "dark"
  },
  "icons": [
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
