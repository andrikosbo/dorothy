# Dorothy Web Client
# Copy to .env and edit.

# Strong private token used by the web UI.
# Generate one:
# openssl rand -hex 32
DOROTHY_WEB_TOKEN=change-me-to-a-long-random-token

# Safer default: only this Mac.
# For iPhone through Tailscale later, set HOST=0.0.0.0
HOST=127.0.0.1
PORT=3030

# Default CLI command used to talk to Dorothy/OpenClaw.
# If your command differs, change it here.
OPENCLAW_AGENT_CMD=openclaw agent

# Optional timeout in ms.
DOROTHY_TIMEOUT_MS=120000
